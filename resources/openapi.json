{
    "openapi": "3.0.0",
    "info": {
        "title": "Backend SAP-UI-5",
        "description": "API documentation for Backend SAP-UI-5",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "/",
            "description": "Server"
        }
    ],
    "paths": {
        "/api/local-so-data": {
            "get": {
                "summary": "API to get data SO Scheduling H-1",
                "description": "T DATA1 dan T DATA2 dari hasil scheduling. Data dikirimkan secara langsung tanpa proses enkripsi.",
                "parameters": [
                    {
                        "name": "X-API-KEY",
                        "in": "header",
                        "required": true,
                        "schema": {
                            "type": "string"
                        },
                        "description": "Secret Key Authentication"
                    },
                    {
                        "name": "iv_werks",
                        "in": "query",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "enum": ["3000", "2000"]
                        }
                    },
                    {
                        "name": "iv_auart",
                        "in": "query",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "enum": ["ZOR2", "ZOR1"]
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Success",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "success": {
                                            "type": "boolean",
                                            "example": true
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "Data successfully retrieved."
                                        },
                                        "data": {
                                            "type": "object",
                                            "description": "Objek JSON mentah berisi t_data1 dan t_data2",
                                            "properties": {
                                                "t_data1": {
                                                    "type": "array",
                                                    "items": { "type": "object" }
                                                },
                                                "t_data2": {
                                                    "type": "array",
                                                    "items": { "type": "object" }
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized - Missing or Invalid Secret Key",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "success": {
                                            "type": "boolean",
                                            "example": false
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "Unauthorized. Secret key is missing or invalid."
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "403": {
                        "description": "Forbidden - Invalid Parameters",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "success": {
                                            "type": "boolean",
                                            "example": false
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "Parameter iv_werks dan iv_auart tidak valid..."
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
